<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider path mapping for SnippetShare.

    <cache-path> maps to context.getCacheDir().
    All snippet PNG files are written to:
        context.cacheDir/snippets/snippet_<timestamp>.png

    The content:// URI generated by FileProvider will look like:
        content://com.example.leoshare.fileprovider/snippets/snippet_1234567890.png
-->
<paths>
    <cache-path
        name="snippets"
        path="snippets/" />
</paths>
