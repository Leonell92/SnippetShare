<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility Service configuration for SnippetShare.

    Key flags:
      canTakeScreenshot="true"  — grants takeScreenshot() API access (Android 11+)
      accessibilityEventTypes="typeAllMask" — must be set but we ignore all events
      feedbackType="feedbackGeneric" — least intrusive feedback type
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeAllMask"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault"
    android:notificationTimeout="100"
    android:canTakeScreenshot="true"
    android:description="@string/accessibility_service_description"
    android:settingsActivity="com.example.leoshare.MainActivity" />
